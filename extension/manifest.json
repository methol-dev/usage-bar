{
  "manifest_version": 3,
  "name": "UsageBar — Claude Web Usage",
  "version": "0.1.0",
  "description": "Reads your claude.ai subscription usage in your own signed-in session and hands it to the UsageBar menu bar app. Never reads or exports cookies.",
  "minimum_chrome_version": "116",
  "key": "",
  "permissions": ["alarms", "nativeMessaging", "scripting"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "UsageBar — Claude Web Usage"
  }
}
